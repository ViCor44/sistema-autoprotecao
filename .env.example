# ====================================
# Configuração da Aplicação
# ====================================

# Ambiente
APP_ENV=development
APP_DEBUG=true
APP_NAME="Sistema Autoproteção"
APP_URL="http://localhost/sistema-autoprotecao"

# ====================================
# Configuração da Base de Dados
# ====================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=sistema_autoprotecao
DB_CHARSET=utf8mb4

# ====================================
# Fuso Horário
# ====================================

TIMEZONE=Europe/Lisbon